generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
  engineType      = "library"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           Int             @id @default(autoincrement())
  nome         String
  email        String          @unique
  senha        String
  role         String
  ativo        Boolean         @default(true)
  criadoEm     DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  vendedorId   Int?
  chatMessages AIChatMessage[]
}

model Vendedor {
  id         Int         @id @default(autoincrement())
  nome       String
  email      String      @unique
  telefone   String
  comissao   Float
  regiao     String
  ativo      Boolean     @default(true)
  criadoEm   DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
  orcamentos Orcamento[]
  pedidos    Pedido[]

  @@index([nome])
  @@index([email])
  @@index([ativo])
}

model Cliente {
  id                  Int               @id @default(autoincrement())
  razaoSocial         String
  nomeFantasia        String?
  cnpj                String            @unique
  ie                  String?
  email               String?
  telefone            String
  compradorNome       String?
  compradorTelefone   String?
  endereco            String
  cep                 String
  cidade              String
  estado              String
  observacoes         String?
  ativo               Boolean           @default(true)
  ultimaCompra        DateTime?
  saldoCreditoValor   Float             @default(0)
  saldoCreditoEtiquetas Int             @default(0)
  criadoEm            DateTime          @default(now())
  updatedAt           DateTime          @updatedAt
  etiquetasExclusivas ClienteEtiqueta[]
  itensExclusivos     ItemExclusivoCliente[]
  movimentacoesCredito MovimentacaoCredito[]
  orcamentos          Orcamento[]
  pedidos             Pedido[]

  @@index([razaoSocial])
  @@index([cnpj])
  @@index([cidade])
  @@index([ativo])
  @@index([ultimaCompra])
  @@index([criadoEm])
}

model Etiqueta {
  id                    Int               @id @default(autoincrement())
  nome                  String
  codigo                String            @unique
  material              String
  tipoAdesivo           String
  largura               Float
  altura                Float
  numeroCores           Int
  tipoTubete            String
  quantidadePorRolo     Int
  metragem              Float?
  preco                 Float?            @default(0)
  coresDescricao        String?
  orientacaoRebobinagem String?
  observacoesTecnicas   String?
  pasta                 String?
  aplicacoesEspeciais   String[]
  ativo                 Boolean           @default(true)
  criadoEm              DateTime          @default(now())
  updatedAt             DateTime          @updatedAt
  clientesAutorizados   ClienteEtiqueta[]
  itensOrcamento        ItemOrcamento[]
  itensPedido           ItemPedido[]

  @@index([nome])
  @@index([codigo])
  @@index([ativo])
  @@index([criadoEm])
}

model ClienteEtiqueta {
  clienteId  Int
  etiquetaId Int
  preco      Float?
  cliente    Cliente  @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  etiqueta   Etiqueta @relation(fields: [etiquetaId], references: [id], onDelete: Cascade)

  @@id([clienteId, etiquetaId])
}

model Empresa {
  id                Int      @id @default(autoincrement())
  razaoSocial       String
  nomeFantasia      String
  cnpj              String   @unique
  inscricaoEstadual String?
  telefone          String
  email             String
  cep               String
  logradouro        String
  numero            String
  complemento       String?
  bairro            String
  cidade            String
  estado            String
  corSidebar        String?
  updatedAt         DateTime @updatedAt
}

model Status {
  id         Int         @id @default(autoincrement())
  nome       String
  ordem      Int
  modulo     String
  cor        String
  ativo      Boolean     @default(true)
  criadoEm   DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
  orcamentos Orcamento[]
  pedidos    Pedido[]

  @@index([modulo, ordem])
}

model Orcamento {
  id           Int             @id @default(autoincrement())
  numero       String          @unique
  clienteId    Int
  vendedorId   Int
  statusId     Int
  observacoes  String?
  ocCliente    String?
  totalGeral   Float
  descontoCredito Float          @default(0)
  prazoEntrega   DateTime?
  ativo          Boolean         @default(true)
  criadoEm     DateTime        @default(now())
  atualizadoEm DateTime        @updatedAt
  formaPagamentoId Int?
  itens        ItemOrcamento[]
  cliente      Cliente         @relation(fields: [clienteId], references: [id])
  statusObj    Status          @relation(fields: [statusId], references: [id])
  vendedor     Vendedor        @relation(fields: [vendedorId], references: [id])
  formaPagamentoObj FormaPagamento? @relation(fields: [formaPagamentoId], references: [id])
  pedidos      Pedido[]

  @@index([clienteId])
  @@index([vendedorId])
  @@index([statusId])
  @@index([criadoEm])
  @@index([ativo])
}

model ItemOrcamento {
  id            Int       @id @default(autoincrement())
  orcamentoId   Int
  etiquetaId    Int?
  descricao     String
  quantidade    Int
  quantidadeCredito Float     @default(0)
  unidade       String
  precoUnitario Float
  total         Float
  observacao    String?
  etiqueta      Etiqueta? @relation(fields: [etiquetaId], references: [id], onDelete: SetNull)
  orcamento     Orcamento @relation(fields: [orcamentoId], references: [id], onDelete: Cascade)

  @@index([orcamentoId])
  @@index([etiquetaId])
}

model Pedido {
  id                     Int          @id @default(autoincrement())
  numero                 String       @unique
  orcamentoId            Int?
  clienteId              Int
  vendedorId             Int
  statusId               Int
  sentidoSaidaRolo       String
  tipoTubete             String
  gapEntreEtiquetas      String
  numeroPistas           Int
  observacoesEmbalagem   String?
  observacoesFaturamento String?
  prazoEntrega           DateTime?
  formaPagamento         String?      @default("A combinar")
  nomeVendedor           String?
  nomeComprador          String?
  frete                  String?
  observacoesGerais      String?
  ocCliente              String?
  totalGeral             Float
  ativo                  Boolean      @default(true)
  criadoEm               DateTime     @default(now())
  atualizadoEm           DateTime     @updatedAt
  formaPagamentoId       Int?
  itens                  ItemPedido[]
  cliente                Cliente      @relation(fields: [clienteId], references: [id])
  orcamento              Orcamento?   @relation(fields: [orcamentoId], references: [id])
  statusObj              Status       @relation(fields: [statusId], references: [id])
  vendedor               Vendedor     @relation(fields: [vendedorId], references: [id])
  formaPagamentoObj      FormaPagamento? @relation(fields: [formaPagamentoId], references: [id])

  @@index([clienteId])
  @@index([vendedorId])
  @@index([statusId])
  @@index([criadoEm])
  @@index([ativo])
}

model ItemPedido {
  id            Int       @id @default(autoincrement())
  pedidoId      Int
  etiquetaId    Int?
  descricao     String
  quantidade    Int
  quantidadeCredito Float     @default(0)
  unidade       String
  precoUnitario Float
  total         Float
  observacao    String?
  etiqueta      Etiqueta? @relation(fields: [etiquetaId], references: [id], onDelete: SetNull)
  pedido        Pedido    @relation(fields: [pedidoId], references: [id], onDelete: Cascade)

  @@index([pedidoId])
  @@index([etiquetaId])
}

model ItemExclusivoCliente {
  id        Int      @id @default(autoincrement())
  clienteId Int
  nome      String
  descricao String?
  preco     Float    @default(0)
  cliente   Cliente  @relation(fields: [clienteId], references: [id], onDelete: Cascade)
}

model MovimentacaoCredito {
  id          Int      @id @default(autoincrement())
  clienteId   Int
  tipo        String   // VALOR ou ETIQUETA
  operacao    String   // CREDITO (Adicionar) ou DEBITO (Remover)
  quantidade  Float
  descricao   String?
  orcamentoId Int?
  criadoEm    DateTime @default(now())
  
  cliente     Cliente   @relation(fields: [clienteId], references: [id], onDelete: Cascade)
}

model FormaPagamento {
  id         Int         @id @default(autoincrement())
  nome       String      @unique
  ativo              Boolean     @default(true)
  quantidadeParcelas Int         @default(1)
  criadoEm           DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
  orcamentos Orcamento[]
  pedidos    Pedido[]
}

model AIConfig {
  id           Int      @id @default(1)
  provider     String   @default("gemini-flash")
  apiKey       String   @default("")
  systemPrompt String   @default("Você é o assistente inteligente da Newflexo, focado em ajudar na gestão de orçamentos, pedidos e produção de etiquetas.")
  monthlyLimit Int      @default(500)
  updatedAt    DateTime @updatedAt
}

model AIChatMessage {
  id        Int      @id @default(autoincrement())
  userId    Int
  role      String
  content   String
  toolCalls Json?
  image     String?
  timestamp DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, timestamp])
}

model AIUsage {
  id         Int      @id @default(autoincrement())
  monthYear  String   @unique
  count      Int      @default(0)
  tokensUsed Int      @default(0)
  updatedAt  DateTime @updatedAt
}
