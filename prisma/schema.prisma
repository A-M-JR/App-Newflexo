generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
  engineType      = "library"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           Int             @id @default(autoincrement())
  nome         String
  email        String          @unique
  senha        String
  role         String
  ativo        Boolean         @default(true)
  criadoEm     DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  vendedorId   Int?
  chatMessages AIChatMessage[]
}

model Vendedor {
  id         Int         @id @default(autoincrement())
  nome       String
  email      String      @unique
  telefone   String
  comissao   Float
  regiao     String
  ativo      Boolean     @default(true)
  criadoEm   DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
  orcamentos Orcamento[]
  pedidos    Pedido[]
}

model Cliente {
  id                  Int               @id @default(autoincrement())
  razaoSocial         String
  cnpj                String            @unique
  ie                  String?
  email               String?
  telefone            String
  endereco            String
  cep                 String
  cidade              String
  estado              String
  observacoes         String?
  ativo               Boolean           @default(true)
  ultimaCompra        DateTime?
  criadoEm            DateTime          @default(now())
  updatedAt           DateTime          @updatedAt
  etiquetasExclusivas ClienteEtiqueta[]
  orcamentos          Orcamento[]
  pedidos             Pedido[]
}

model Etiqueta {
  id                    Int               @id @default(autoincrement())
  nome                  String
  codigo                String            @unique
  material              String
  tipoAdesivo           String
  largura               Float
  altura                Float
  numeroCores           Int
  tipoTubete            String
  quantidadePorRolo     Int
  metragem              Float?
  coresDescricao        String?
  orientacaoRebobinagem String?
  observacoesTecnicas   String?
  pasta                 String?
  aplicacoesEspeciais   String[]
  ativo                 Boolean           @default(true)
  criadoEm              DateTime          @default(now())
  updatedAt             DateTime          @updatedAt
  clientesAutorizados   ClienteEtiqueta[]
  itensOrcamento        ItemOrcamento[]
  itensPedido           ItemPedido[]
}

model ClienteEtiqueta {
  clienteId  Int
  etiquetaId Int
  cliente    Cliente  @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  etiqueta   Etiqueta @relation(fields: [etiquetaId], references: [id], onDelete: Cascade)

  @@id([clienteId, etiquetaId])
}

model Empresa {
  id                Int      @id @default(autoincrement())
  razaoSocial       String
  nomeFantasia      String
  cnpj              String   @unique
  inscricaoEstadual String?
  telefone          String
  email             String
  cep               String
  logradouro        String
  numero            String
  complemento       String?
  bairro            String
  cidade            String
  estado            String
  corSidebar        String?
  updatedAt         DateTime @updatedAt
}

model Status {
  id         Int         @id @default(autoincrement())
  nome       String
  ordem      Int
  modulo     String
  cor        String
  ativo      Boolean     @default(true)
  criadoEm   DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
  orcamentos Orcamento[]
  pedidos    Pedido[]

  @@index([modulo, ordem])
}

model Orcamento {
  id           Int             @id @default(autoincrement())
  numero       String          @unique
  clienteId    Int
  vendedorId   Int
  statusId     Int
  observacoes  String?
  totalGeral   Float
  ativo        Boolean         @default(true)
  criadoEm     DateTime        @default(now())
  atualizadoEm DateTime        @updatedAt
  itens        ItemOrcamento[]
  cliente      Cliente         @relation(fields: [clienteId], references: [id])
  statusObj    Status          @relation(fields: [statusId], references: [id])
  vendedor     Vendedor        @relation(fields: [vendedorId], references: [id])
  pedidos      Pedido[]
}

model ItemOrcamento {
  id            Int       @id @default(autoincrement())
  orcamentoId   Int
  etiquetaId    Int?
  descricao     String
  quantidade    Int
  unidade       String
  precoUnitario Float
  total         Float
  etiqueta      Etiqueta? @relation(fields: [etiquetaId], references: [id])
  orcamento     Orcamento @relation(fields: [orcamentoId], references: [id], onDelete: Cascade)
}

model Pedido {
  id                     Int          @id @default(autoincrement())
  numero                 String       @unique
  orcamentoId            Int?
  clienteId              Int
  vendedorId             Int
  statusId               Int
  sentidoSaidaRolo       String
  tipoTubete             String
  gapEntreEtiquetas      String
  numeroPistas           Int
  observacoesEmbalagem   String?
  observacoesFaturamento String?
  prazoEntrega           String
  formaPagamento         String
  nomeVendedor           String?
  nomeComprador          String?
  frete                  String?
  observacoesGerais      String?
  totalGeral             Float
  ativo                  Boolean      @default(true)
  criadoEm               DateTime     @default(now())
  atualizadoEm           DateTime     @updatedAt
  itens                  ItemPedido[]
  cliente                Cliente      @relation(fields: [clienteId], references: [id])
  orcamento              Orcamento?   @relation(fields: [orcamentoId], references: [id])
  statusObj              Status       @relation(fields: [statusId], references: [id])
  vendedor               Vendedor     @relation(fields: [vendedorId], references: [id])
}

model ItemPedido {
  id            Int       @id @default(autoincrement())
  pedidoId      Int
  etiquetaId    Int?
  descricao     String
  quantidade    Int
  unidade       String
  precoUnitario Float
  total         Float
  etiqueta      Etiqueta? @relation(fields: [etiquetaId], references: [id])
  pedido        Pedido    @relation(fields: [pedidoId], references: [id], onDelete: Cascade)
}

model AIConfig {
  id           Int      @id @default(1)
  provider     String   @default("gemini-flash")
  apiKey       String   @default("")
  systemPrompt String   @default("Você é o assistente inteligente da Newflexo, focado em ajudar na gestão de orçamentos, pedidos e produção de etiquetas.")
  monthlyLimit Int      @default(500)
  updatedAt    DateTime @updatedAt
}

model AIChatMessage {
  id        Int      @id @default(autoincrement())
  userId    Int
  role      String
  content   String
  toolCalls Json?
  image     String?
  timestamp DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, timestamp])
}

model AIUsage {
  id         Int      @id @default(autoincrement())
  monthYear  String   @unique
  count      Int      @default(0)
  tokensUsed Int      @default(0)
  updatedAt  DateTime @updatedAt
}
